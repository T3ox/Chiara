<Window x:Class="FolderOrganizer.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        mc:Ignorable="d"
        Title="FolderOrganizer Desktop Preview"
        Width="1440"
        Height="920"
        MinWidth="980"
        MinHeight="640"
        WindowStartupLocation="CenterScreen"
        Background="#0b1325">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <Border Grid.Row="0"
            Background="#111b35"
            BorderBrush="#22345a"
            BorderThickness="0,0,0,1"
            Padding="14,10">
      <DockPanel>
        <TextBlock Foreground="#dce7f7"
                   FontSize="14"
                   FontWeight="SemiBold"
                   Text="FolderOrganizer - Desktop Preview" />
        <TextBlock x:Name="PathText"
                   Margin="12,0,0,0"
                   Foreground="#9eb0ca"
                   FontSize="12"
                   TextTrimming="CharacterEllipsis"
                   VerticalAlignment="Center"
                   DockPanel.Dock="Right" />
      </DockPanel>
    </Border>

    <wv2:WebView2 x:Name="Browser"
                  Grid.Row="1"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch"
                  DefaultBackgroundColor="#0b1325" />
  </Grid>
</Window>
