<Window x:Class="FolderOrganizerLauncher.Features.Updates.Views.UpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:FolderOrganizerLauncher.Features.Updates.ViewModels"
        mc:Ignorable="d"
        Title="Aggiornamento Disponibile" Height="450" Width="500"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#1E1E1E" Foreground="White">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Text="È disponibile una nuova versione!" FontSize="20" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,0,0,15" Foreground="#007ACC"/>

        <!-- Version Info -->
        <StackPanel Grid.Row="1" Orientation="Vertical" Margin="0,0,0,15">
            <TextBlock Text="{Binding CurrentVersion}" FontSize="14" Foreground="#AAAAAA" Margin="0,2,0,2"/>
            <TextBlock Text="{Binding LatestVersion}" FontSize="14" FontWeight="SemiBold" Foreground="#00CC7A" Margin="0,2,0,2"/>
        </StackPanel>

        <!-- Changelog -->
        <Border Grid.Row="2" Background="#2D2D30" BorderBrush="#444" BorderThickness="1" CornerRadius="5" Padding="10">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <TextBlock Text="- Miglioramenti alle prestazioni&#x0a;- Nuove funzionalità aggiunte&#x0a;- Bug fix vari" 
                           Foreground="#DDDDDD" TextWrapping="Wrap" FontSize="12"/>
            </ScrollViewer>
        </Border>

        <!-- Buttons -->
        <Grid Grid.Row="3" Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Later Button -->
            <Button Grid.Column="0" Content="Più tardi" Command="{Binding LaterCommand}"
                    Padding="10,8" FontSize="14" Foreground="White" BorderThickness="1" BorderBrush="#555">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#333333"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}"
                                            BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#555555"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>

            <!-- Update Now Button -->
            <Button Grid.Column="2" Content="Aggiorna ora" Command="{Binding UpdateNowCommand}"
                    Padding="10,8" FontSize="14" Foreground="White" BorderThickness="0" FontWeight="Bold">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#007ACC"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#005A9E"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>
    </Grid>
</Window>
