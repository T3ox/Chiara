<Window x:Class="FolderOrganizerLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Folder Organizer Launcher" Height="450" Width="800"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E" Foreground="White"
        Loaded="Window_Loaded">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Text="Folder Organizer" FontSize="32" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,0,0,20" Foreground="#007ACC"/>

        <!-- Drag & Drop Zone -->
        <Border Grid.Row="1" x:Name="DropZone" 
                BorderBrush="#444" BorderThickness="2" CornerRadius="10" 
                Background="#2D2D30" AllowDrop="True"
                Drop="DropZone_Drop" DragOver="DropZone_DragOver">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="📂" FontSize="48" HorizontalAlignment="Center" Foreground="#888"/>
                <TextBlock Text="Trascinare qui la cartella" FontSize="18" Foreground="#AAA" Margin="0,10,0,0"/>
                <TextBlock x:Name="SelectedPathText" Text="Nessuna cartella selezionata" 
                           FontSize="14" Foreground="#666" Margin="0,5,0,0" TextWrapping="Wrap" MaxWidth="600" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Status Message -->
        <TextBlock x:Name="StatusText" Grid.Row="2" Text="" Foreground="#aaaaaa" HorizontalAlignment="Center" Margin="0,10,0,0"/>

        <!-- Confirm Button -->
        <Button Grid.Row="3" Content="Conferma Selezione" 
                FontSize="16" Padding="20,10" Margin="0,20,0,0"
                HorizontalAlignment="Center"
                Foreground="White" BorderThickness="0"
                Click="ConfirmButton_Click">
            <Button.Style>
                <Style TargetType="Button">
                    <Setter Property="Background" Value="#007ACC"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <EventTrigger RoutedEvent="MouseEnter">
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <ColorAnimation Storyboard.TargetName="border" 
                                                                Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" 
                                                                To="#005A9E" Duration="0:0:0.2"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                    <EventTrigger RoutedEvent="MouseLeave">
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <ColorAnimation Storyboard.TargetName="border" 
                                                                Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" 
                                                                To="#007ACC" Duration="0:0:0.2"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Button.Style>
        </Button>
    </Grid>
</Window>
